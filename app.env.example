# ================================================================
# InvoBill — Configuration File
# ================================================================
# Copy this file to app.env and fill in your values.
# app.env is gitignored — never commit it.
#
#   cp app.env.example app.env
# ================================================================


# ── Server ───────────────────────────────────────────────────────
PORT=8080


# ── Database (MySQL) ─────────────────────────────────────────────
# Format: user:password@tcp(host:port)/dbname?parseTime=true&charset=utf8mb4
# parseTime=true is REQUIRED.
DATABASE_DSN=root:@tcp(127.0.0.1:3306)/invobill?parseTime=true&charset=utf8mb4


# ── GST / PDF Invoices ───────────────────────────────────────────
# These values appear on every generated PDF invoice.
GST_SELLER_NAME=InvoBill Company
GST_SELLER_GSTIN=27AABCU9603R1ZX
GST_SELLER_ADDRESS=123, Business Park, Mumbai, MH 400001
# GST_STATE_CODE is auto-derived from first 2 digits of GSTIN.
# Override only if needed:
# GST_STATE_CODE=27


# ── Email / SMTP ─────────────────────────────────────────────────
# Leave SMTP_HOST empty to disable email (NoopMailer).
# All transactional emails (invoices, welcome, contact) are skipped.
#
# Gmail example:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=you@gmail.com
#   SMTP_PASS=xxxx-xxxx-xxxx-xxxx   ← Gmail App Password (not your login password)
#   SMTP_FROM=you@gmail.com
#
# Other providers (Mailgun, Brevo, SES, Zoho) — just change host/port/user/pass.

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@invobill.in


# ── Contact Form ─────────────────────────────────────────────────
# Email address that receives contact form submissions.
# Falls back to SMTP_FROM if not set.
CONTACT_EMAIL=admin@invobill.in
